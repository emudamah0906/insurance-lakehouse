# Snowflake credentials — copy to .env and fill in your values
# cp .env.example .env

SNOWFLAKE_ACCOUNT=<your-account-locator>.ca-central-1.aws
SNOWFLAKE_USER=<YOUR_SNOWFLAKE_USER>
SNOWFLAKE_PASSWORD=<your-password>
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_DATABASE=INSURANCE_DW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=STAGING
